{
  "name": "oracle-claim-scanner",
  "version": "1.0.0",
  "description": "COMPLIANCELINC — Oracle Oasis+ claim scanner on Cloudflare Workers",
  "main": "src/index.js",
  "scripts": {
    "build": "npm run lint && npm test",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:portals": "wrangler deploy --config wrangler.toml",
    "deploy:scanner": "wrangler deploy --config wrangler.scanner.toml",
    "setup": "node setup.mjs",
    "lint": "eslint . --ext .js,.mjs",
    "test": "node tests/complete-interface-test.mjs",
    "audit:deps": "npm audit --omit=dev"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.0.6"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "wrangler": "^4.77.0"
  }
}
