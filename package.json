{
  "name": "oracle-setup",
  "version": "1.0.0",
  "description": "BrainSAIT control plane, Oracle scanner, and infrastructure automation toolkit",
  "main": "src/index.js",
  "bin": {
    "brainsait-oracle": "./scripts/brainsait-oracle.mjs"
  },
  "scripts": {
    "build": "npm run lint && npm test",
    "cli": "node scripts/brainsait-oracle.mjs",
    "configure": "bash scripts/configure.sh",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:portals": "wrangler deploy --config wrangler.toml",
    "deploy:scanner": "wrangler deploy --config wrangler.scanner.toml",
    "deploy:edge-router": "wrangler deploy --config infra-v3/edge-router/wrangler.toml",
    "cloudflare:bos:bootstrap": "node scripts/cloudflare-bos-bootstrap.mjs",
    "oracle:dev": "node scripts/brainsait-oracle.mjs deploy --target local-dev",
    "oracle:status": "node scripts/brainsait-oracle.mjs status",
    "oracle:backup": "node scripts/brainsait-oracle.mjs backup",
    "resubmission:plan": "node scripts/build-resubmission-plan.mjs",
    "setup": "node setup.mjs",
    "lint": "eslint . --ext .js,.mjs",
    "test": "node tests/complete-interface-test.mjs",
    "audit:deps": "npm audit --omit=dev"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.0.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "wrangler": "^4.77.0"
  }
}
